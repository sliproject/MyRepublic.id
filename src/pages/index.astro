<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MyRepublic — Paket Internet Fiber Optic Terbaik</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --navy:        #0d0a0b;
            --navy2:       #1a0f10;
            --navy3:       #2a1215;
            --accent:      #e30613;
            --accent2:     #ff3344;
            --accent-glow: rgba(227,6,19,0.15);
            --text:        #f5e8e9;
            --text-muted:  #b89496;
            --border:      rgba(227,6,19,0.22);
            --border-soft: rgba(255,255,255,0.06);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--navy);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.6;
        }
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image:
                linear-gradient(rgba(227,6,19,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(227,6,19,0.04) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none; z-index: 0;
        }
        .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

        /* ── NAVBAR ── */
        nav {
            position: fixed; top: 0; left: 0; right: 0;
            padding: 0; z-index: 999;
            border-bottom: 1px solid var(--border-soft);
            backdrop-filter: blur(20px);
            background: rgba(13,10,11,0.88);
        }
        .nav-inner {
            max-width: 1120px; margin: 0 auto; padding: 0 24px;
            display: flex; justify-content: space-between; align-items: center;
            height: 68px;
        }
        .logo {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px; font-weight: 700;
            text-decoration: none; color: var(--text);
            letter-spacing: -0.5px;
            display: flex; align-items: center; gap: 10px;
        }
        .logo img { height: 36px; width: auto; }
        .nav-links { display: flex; align-items: center; gap: 6px; }
        .nav-links a {
            text-decoration: none; color: var(--text-muted);
            font-size: 14px; font-weight: 500;
            padding: 8px 16px; border-radius: 8px;
            transition: all 0.2s;
        }
        .nav-links a:hover { color: var(--text); background: var(--border-soft); }
        .btn-nav-cta {
            background: var(--accent) !important;
            color: white !important;
            border-radius: 8px !important;
            font-weight: 600 !important;
        }
        .btn-nav-cta:hover { background: var(--accent2) !important; }
        @media (max-width: 768px) { .nav-links { display: none; } }

        /* ── HERO ── */
        .hero {
            min-height: 60vh;
            display: flex; align-items: center;
            padding: 120px 0 60px;
            position: relative; overflow: hidden;
            text-align: center;
        }
        .hero-glow {
            position: absolute; top: 20%; left: 50%;
            transform: translateX(-50%);
            width: 800px; height: 400px;
            background: radial-gradient(ellipse, rgba(227,6,19,0.13) 0%, transparent 70%);
            pointer-events: none;
        }
        .orb {
            position: absolute; border-radius: 50%;
            filter: blur(80px); pointer-events: none;
            animation: float 8s ease-in-out infinite;
        }
        .orb1 { width: 260px; height: 260px; background: rgba(227,6,19,0.08); top: 15%; left: 5%; }
        .orb2 { width: 180px; height: 180px; background: rgba(180,20,30,0.06); top: 55%; right: 5%; animation-delay: -3s; }
        @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(227,6,19,0.08);
            border: 1px solid var(--border);
            padding: 6px 16px; border-radius: 100px;
            font-size: 12px; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; color: var(--accent2);
            margin-bottom: 28px;
        }
        .eyebrow-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--accent);
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.5; transform:scale(.8); } }

        .hero h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(36px, 6vw, 64px);
            font-weight: 700; line-height: 1.08;
            letter-spacing: -2px; color: #fff;
            margin-bottom: 20px;
        }
        .h1-accent {
            background: linear-gradient(90deg, var(--accent), var(--accent2), #ff8c94);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero p {
            font-size: 17px; color: var(--text-muted);
            max-width: 540px; margin: 0 auto 36px; line-height: 1.7;
        }
        .hero-badges {
            display: flex; gap: 10px; justify-content: center;
            flex-wrap: wrap; margin-bottom: 36px;
        }
        .hero-badge {
            background: var(--navy2);
            border: 1px solid var(--border-soft);
            padding: 6px 14px; border-radius: 8px;
            font-size: 13px; font-weight: 600; color: var(--text-muted);
            display: flex; align-items: center; gap: 6px;
        }
        .hero-badge .ok { color: #4ade80; }
        .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        .btn-primary {
            background: var(--accent); color: white;
            padding: 14px 28px; border-radius: 10px;
            text-decoration: none; font-weight: 600; font-size: 15px;
            display: inline-flex; align-items: center; gap: 8px;
            transition: all 0.25s;
        }
        .btn-primary:hover { background: var(--accent2); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(227,6,19,0.3); }
        .btn-ghost {
            background: transparent; color: var(--text);
            border: 1px solid var(--border);
            padding: 14px 28px; border-radius: 10px;
            text-decoration: none; font-weight: 600; font-size: 15px;
            display: inline-flex; align-items: center; gap: 8px;
            transition: all 0.25s;
        }
        .btn-ghost:hover { background: var(--border-soft); border-color: var(--accent); color: var(--accent2); transform: translateY(-2px); }

        /* ── STATS BAR ── */
        .stats-bar {
            padding: 32px 0;
            border-top: 1px solid var(--border-soft);
            border-bottom: 1px solid var(--border-soft);
            background: rgba(26,15,16,0.6);
        }
        .stats-inner { display: grid; grid-template-columns: repeat(4,1fr); gap: 0; }
        .stat-item { text-align: center; padding: 16px; border-right: 1px solid var(--border-soft); }
        .stat-item:last-child { border-right: none; }
        .stat-num {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 36px; font-weight: 700; color: var(--accent);
            line-height: 1; margin-bottom: 4px;
        }
        .stat-label { font-size: 13px; color: var(--text-muted); font-weight: 500; }
        @media (max-width: 640px) {
            .stats-inner { grid-template-columns: repeat(2,1fr); }
            .stat-item:nth-child(2) { border-right: none; }
            .stat-item:nth-child(3),
            .stat-item:nth-child(4) { border-top: 1px solid var(--border-soft); }
            .stat-item:nth-child(4) { border-right: none; }
        }

        /* ── SECTION COMMON ── */
        .section-label {
            font-size: 12px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--accent); margin-bottom: 12px;
        }
        .section-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(28px, 4vw, 44px);
            font-weight: 700; letter-spacing: -1px;
            color: #fff; margin-bottom: 12px;
        }
        .section-sub {
            font-size: 16px; color: var(--text-muted);
            max-width: 520px; margin-bottom: 48px; line-height: 1.7;
        }

        /* ── KEUNGGULAN BAR ── */
        .keunggulan { padding: 72px 0; background: var(--navy2); border-bottom: 1px solid var(--border-soft); }
        .k-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 0; }
        .k-item { padding: 24px 28px; border-right: 1px solid var(--border-soft); }
        .k-item:last-child { border-right: none; }
        .k-icon { font-size: 28px; margin-bottom: 10px; }
        .k-title { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
        .k-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; }
        @media (max-width: 640px) {
            .k-grid { grid-template-columns: 1fr 1fr; }
            .k-item { border-bottom: 1px solid var(--border-soft); }
            .k-item:nth-child(even) { border-right: none; }
        }

        /* ── PRICING ── */
        .pricing { padding: 88px 0; position: relative; }

        /* Main tabs */
        .pricing-tabs { display: flex; gap: 10px; margin-bottom: 40px; flex-wrap: wrap; }
        .ptab {
            padding: 10px 22px; border-radius: 50px;
            border: 1px solid var(--border-soft);
            background: var(--navy2); color: var(--text-muted);
            font-size: 14px; font-weight: 600; cursor: pointer;
            transition: all 0.22s; font-family: 'Inter', sans-serif;
        }
        .ptab.active, .ptab:hover { background: var(--accent); border-color: var(--accent); color: #fff; }
        .pricing-panel { display: none; }
        .pricing-panel.active { display: block; }

        /* Sub-tabs */
        .pricing-subtabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
        .psubtab {
            padding: 7px 16px; border-radius: 8px;
            border: 1px solid var(--border-soft);
            background: transparent; color: var(--text-muted);
            font-size: 13px; font-weight: 500; cursor: pointer;
            transition: all 0.2s; font-family: 'Inter', sans-serif;
        }
        .psubtab.active, .psubtab:hover {
            background: rgba(227,6,19,0.18);
            border-color: var(--accent); color: #ffaaad;
        }
        .subpanel { display: none; }
        .subpanel.active { display: block; }

        /* Package cards */
        .pkg-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px,1fr)); gap: 14px; }
        .pkg-card {
            background: var(--navy2); border: 1px solid var(--border-soft);
            border-radius: 16px; padding: 26px 22px;
            position: relative; transition: all 0.28s;
        }
        .pkg-card:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 32px rgba(227,6,19,0.18); }
        .pkg-card.featured { border-color: var(--accent); background: linear-gradient(135deg, rgba(227,6,19,0.12), rgba(180,10,20,0.05)); }
        .pkg-badge {
            position: absolute; top: -10px; right: 14px;
            background: linear-gradient(90deg, var(--accent), #c00010);
            color: #fff; font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 50px; letter-spacing: 0.5px;
        }
        .pkg-name { font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 6px; }
        .pkg-speed {
            display: inline-block;
            background: rgba(227,6,19,0.18); border: 1px solid rgba(227,6,19,0.35);
            color: #ffaaad; font-size: 12px; font-weight: 700;
            padding: 3px 10px; border-radius: 6px; margin-bottom: 14px;
        }
        .pkg-upgrade { font-size: 11px; color: #fbbf24; margin-bottom: 10px; display: block; }
        .pkg-price { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 4px; }
        .pkg-price-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 14px; }
        .pkg-bonus {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.25);
            color: #fbbf24; font-size: 12px; font-weight: 600;
            padding: 4px 10px; border-radius: 6px; margin-bottom: 14px;
        }
        .pkg-features { display: flex; flex-direction: column; gap: 5px; margin-top: 14px; }
        .pkg-feat { font-size: 12.5px; color: var(--text-muted); display: flex; align-items: flex-start; gap: 6px; }
        .pkg-feat::before { content: '✓'; color: #4ade80; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
        .pkg-note {
            font-size: 12px; color: var(--text-muted); text-align: center;
            margin-top: 20px; padding: 10px 14px;
            background: rgba(255,255,255,0.03);
            border-radius: 8px; border: 1px solid var(--border-soft);
        }

        /* Lippo area note */
        .lippo-note {
            font-size: 14px; color: var(--text-muted); margin-bottom: 24px;
            padding: 14px 18px;
            background: rgba(227,6,19,0.06);
            border: 1px solid rgba(227,6,19,0.15);
            border-radius: 10px;
        }

        /* AP Table */
        .ap-table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border-soft); }
        .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .ap-table thead th {
            background: rgba(227,6,19,0.18); color: #ffaaad;
            font-weight: 700; padding: 10px 13px;
            text-align: left; white-space: nowrap;
            border-bottom: 1px solid var(--border-soft);
        }
        .ap-table thead th.center { text-align: center; }
        .ap-table tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }
        .ap-table tbody tr:hover { background: rgba(227,6,19,0.07); }
        .ap-table td { padding: 8px 13px; color: var(--text-muted); border-bottom: 1px solid rgba(255,255,255,0.04); white-space: nowrap; }
        .ap-table td.bold { color: #fff; font-weight: 600; }
        .ap-table td.center { text-align: center; }
        .ap-table td.red { color: #ffaaad; font-weight: 600; }
        .ap-table .ap-section td {
            background: rgba(227,6,19,0.12); color: #ff8c94;
            font-weight: 700; font-size: 12px;
            letter-spacing: 1px; text-transform: uppercase; padding: 6px 13px;
        }
        .ap-na { color: #ef4444 !important; font-weight: 700; }

        /* ── CTA BAND ── */
        .cta-band {
            padding: 72px 0;
            border-top: 1px solid var(--border-soft);
        }
        .cta-box {
            background: var(--navy2); border: 1px solid var(--border);
            border-radius: 20px; padding: 60px 48px; text-align: center;
            position: relative; overflow: hidden;
        }
        .cta-box::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(227,6,19,0.1) 0%, transparent 60%);
            pointer-events: none;
        }
        .cta-box h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px,4vw,38px); font-weight: 700; letter-spacing: -1px; color: #fff; margin-bottom: 12px; }
        .cta-box p { font-size: 15px; color: var(--text-muted); margin-bottom: 28px; }
        .cta-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        @media (max-width: 640px) { .cta-box { padding: 40px 24px; } }

        /* ── FOOTER ── */
        footer { border-top: 1px solid var(--border-soft); padding: 36px 0; text-align: center; }
        .footer-logo { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; }
        .footer-logo span { color: var(--accent); }
        footer p { font-size: 13px; color: var(--text-muted); }

        /* ── DUAL CHAT BUTTONS ── */
        .chat-buttons {
            position: fixed; bottom: 28px; right: 28px;
            display: flex; flex-direction: column; gap: 10px;
            align-items: flex-end; z-index: 1001;
        }
        .chat-btn {
            display: flex; align-items: center; gap: 8px;
            border: none; border-radius: 50px;
            padding: 12px 20px; font-weight: 700; font-size: 13px;
            cursor: pointer; transition: all 0.25s;
            font-family: 'Inter', sans-serif; white-space: nowrap;
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }
        .chat-btn-paket { background: var(--accent); color: white; }
        .chat-btn-paket:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(227,6,19,0.5); }
        .chat-btn-komplain { background: #991b1b; color: white; }
        .chat-btn-komplain:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(153,27,27,0.5); }
        .chat-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; animation: pulse 2s infinite; }

        /* ── CHAT WINDOWS ── */
        .chat-window {
            position: fixed; bottom: 100px; right: 28px;
            width: 380px; height: 540px;
            background: var(--navy2); border: 1px solid var(--border);
            border-radius: 20px; display: none; flex-direction: column;
            box-shadow: 0 24px 60px rgba(0,0,0,0.5);
            z-index: 1002; overflow: hidden; font-family: 'Inter', sans-serif;
        }
        .chat-window.show { display: flex; animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1); }
        @keyframes slideUp { from { opacity:0; transform:translateY(16px) scale(.97); } to { opacity:1; transform:translateY(0) scale(1); } }

        .chat-header { padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; }
        .chat-header.paket-header   { background: linear-gradient(135deg, #8b0000, #e30613); }
        .chat-header.komplain-header { background: linear-gradient(135deg, #6b0000, #991b1b); }

        .chat-agent { display: flex; align-items: center; gap: 12px; }
        .agent-avatar { width: 38px; height: 38px; border-radius: 10px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 18px; }
        .agent-name { font-weight: 700; font-size: 14px; color: white; }
        .agent-status { font-size: 12px; color: rgba(255,255,255,0.75); display: flex; align-items: center; gap: 5px; }
        .status-online { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; }
        .close-chat { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 22px; cursor: pointer; padding: 0 4px; line-height: 1; }
        .close-chat:hover { color: white; }

        .chat-body { flex: 1; padding: 16px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; background: var(--navy); }
        .chat-body::-webkit-scrollbar { width: 4px; }
        .chat-body::-webkit-scrollbar-thumb { background: var(--border-soft); border-radius: 2px; }

        .msg { padding: 10px 14px; border-radius: 14px; font-size: 13.5px; line-height: 1.5; max-width: 82%; word-break: break-word; }
        .msg.bot  { background: var(--navy2); color: var(--text); border: 1px solid var(--border-soft); border-bottom-left-radius: 4px; align-self: flex-start; }
        .msg.user { background: #b91c1c; color: white; border-bottom-right-radius: 4px; align-self: flex-end; }
        .msg.system { background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.25); color: #fbbf24; font-size: 12px; border-radius: 8px; align-self: center; max-width: 90%; text-align: center; padding: 8px 12px; }

        .typing { display: flex; gap: 4px; align-items: center; padding: 12px 16px; background: var(--navy2); border: 1px solid var(--border-soft); border-radius: 14px; border-bottom-left-radius: 4px; align-self: flex-start; }
        .typing span { width: 7px; height: 7px; border-radius: 50%; background: var(--text-muted); animation: bounce 1.4s infinite; }
        .typing span:nth-child(2) { animation-delay: 0.2s; }
        .typing span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce { 0%,80%,100% { transform:translateY(0); } 40% { transform:translateY(-6px); } }

        .chat-footer { padding: 12px 14px; border-top: 1px solid var(--border-soft); display: flex; gap: 8px; background: var(--navy2); }
        .chat-input {
            flex: 1; background: var(--navy); border: 1px solid var(--border-soft);
            color: var(--text); padding: 10px 14px; border-radius: 10px;
            font-size: 13.5px; outline: none; transition: border-color 0.2s;
            font-family: 'Inter', sans-serif;
        }
        .chat-input:focus { border-color: var(--accent); }
        .chat-input::placeholder { color: var(--text-muted); }
        .chat-send { background: var(--accent); color: white; border: none; width: 42px; border-radius: 10px; cursor: pointer; font-size: 16px; transition: background 0.2s; }
        .chat-send:hover { background: var(--accent2); }
        .chat-send.dark { background: #991b1b; }
        .chat-send.dark:hover { background: #7f1d1d; }

        /* ── REVEAL ANIMATION ── */
        @keyframes fadeInUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
        .reveal { opacity:0; transform:translateY(24px); transition: opacity .6s ease, transform .6s ease; }
        .reveal.visible { opacity:1; transform:translateY(0); }

        @media (max-width: 480px) {
            .chat-window { width: calc(100vw - 24px); right: 12px; bottom: 84px; height: 480px; }
            .chat-buttons { right: 12px; bottom: 12px; }
            .pkg-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 768px) {
            .pkg-grid { grid-template-columns: 1fr 1fr; }
        }
        @media (prefers-reduced-motion: reduce) { *, .orb { animation: none !important; transition: none !important; } }
    </style>
</head>
<body>

    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <!-- ── NAVBAR ── -->
    <nav>
        <div class="nav-inner">
            <a href="#" class="logo">
                <!-- Ganti src dengan logo MyRepublic jika ada -->
                <span style="font-family:'Space Grotesk',sans-serif;font-size:20px;font-weight:800;color:#fff;">My<span style="color:var(--accent);">Republic</span></span>
            </a>
            <div class="nav-links">
                <a href="#harga">Paket</a>
