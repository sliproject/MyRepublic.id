    <script>
        // Chat Widget Toggle
        const chatBtn = document.getElementById('chatBtn');
        const chatWidget = document.getElementById('chatWidget');
        const closeChat = document.getElementById('closeChat');

        chatBtn.addEventListener('click', () => {
            chatWidget.classList.add('active');
            chatBtn.classList.add('hidden');
        });

        closeChat.addEventListener('click', () => {
            chatWidget.classList.remove('active');
            chatBtn.classList.remove('hidden');
        });

        // Chat Message Functionality
        const input = document.querySelector('.chat-input-area input');
        const button = document.querySelector('.chat-send-btn');
        const messagesContainer = document.querySelector('.chat-messages');

        button.addEventListener('click', sendMessage);
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        function sendMessage() {
            const text = input.value.trim();
            if (!text) return;

            const userMsg = document.createElement('div');
            userMsg.className = 'message user';
            userMsg.innerHTML = `<div class="message-bubble">${text}</div>`;
            messagesContainer.appendChild(userMsg);

            input.value = '';
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            setTimeout(() => {
                const botMsg = document.createElement('div');
                botMsg.className = 'message bot';
                botMsg.innerHTML = `<div class="message-bubble">Terima kasih atas pertanyaan Anda! Tim kami akan segera merespons secara lebih detail.</div>`;
                messagesContainer.appendChild(botMsg);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 500);
        }
    </script>
