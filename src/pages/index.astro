    <!-- ============================================================
       LOGIKA JAVASCRIPT LIVE CHAT & INTEGRASI WEBHOOK N8N
       ============================================================ -->
    <script>
        const chatToggle = document.getElementById('chat-toggle');
        const chatBox = document.getElementById('chat-box');
        const closeChat = document.getElementById('close-chat');
        const toggleIcon = document.getElementById('toggle-icon');
        const chatMessages = document.getElementById('chat-messages');
        const chatForm = document.getElementById('chat-form');
        const userInput = document.getElementById('user-input');

        // Bikin Session ID Unik bawaan SLi Project
        const sessionId = "SLI_" + btoa(Math.random().toString()).substring(0, 10);

        // Buka / Tutup Jendela Chat
        chatToggle.addEventListener('click', () => {
            chatBox.classList.toggle('hidden');
            if (chatBox.classList.contains('hidden')) {
                toggleIcon.className = "fas fa-comments";
            } else {
                toggleIcon.className = "fas fa-chevron-down";
                userInput.focus();
            }
        });

        closeChat.addEventListener('click', () => {
            chatBox.classList.add('hidden');
            toggleIcon.className = "fas fa-comments";
        });

        // FUNGSI INJEKSI PESAN (SUDAH DIPERBAIKI TOTAL AGAR TERPISAH KANAN-KIRI)
        function addMsg(text, sender) {
            // 1. Buat element row pembungkus utama
            const row = document.createElement('div');
            row.className = `msg-row ${sender}`; // Mengisi class 'msg-row user' atau 'msg-row bot'

            // 2. Buat element bubble chat di dalamnya
            const bubble = document.createElement('div');
            bubble.className = 'chat-bubble';
            bubble.innerText = text;

            // 3. Masukkan bubble ke dalam row, lalu row ke box chat
            row.appendChild(bubble);
            chatMessages.appendChild(row);
            
            // Auto scroll otomatis ke dasar obrolan terbaru
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // FUNGSI INDIKATOR MENGETIK (TYPING INDICATOR) BOT
        function showTyping() {
            hideTyping(); // Bersihkan indikator ganda jika ada antrean
            const typingDiv = document.createElement('div');
            typingDiv.className = 'typing-indicator';
            typingDiv.id = 'bot-typing-node';
            typingDiv.innerHTML = '<span></span><span></span><span></span>';
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function hideTyping() {
            const typingNode = document.getElementById('bot-typing-node');
            if (typingNode) typingNode.remove();
        }

        // Tampilkan Pesan Pertama Bot saat Halaman Dimuat Selesai
        window.addEventListener('load', () => {
            setTimeout(() => {
                addMsg('Halo! Selamat datang di SLi Project. Ada yang bisa asisten AI kami bantu mengenai integrasi sistem atau otomatisasi bisnis Anda? 👋', 'bot');
            }, 1000);
        });

        // Event Handler Pengiriman Pesan Ke Webhook n8n
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const messageText = userInput.value.trim();
            if (!messageText) return;

            // Tampilkan teks user langsung di sebelah kanan (Warna Biru)
            addMsg(messageText, 'user');
            userInput.value = ''; // Kosongkan kolom input
            
            // Munculkan efek animasi titik tiga mengetik di sebelah kiri
            showTyping();

            try {
                // Fetch data POST ke webhook n8n milik lu tanpa mengubah endpoint
                const response = await fetch('https://n8n.aleshatour.my.id/webhook/website', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: messageText, chatId: sessionId })
                });

                const data = await response.json();
                hideTyping(); // Hapus indikator mengetik

                // Ekstrak parameter balasan n8n secara fleksibel
                const botReply = data.reply || data.output || data.message || 'Tim SLi Project akan segera merespon pesan Anda secara manual.';
                
                // Tampilkan balasan bot di sebelah kiri (Warna Abu-abu)
                addMsg(botReply, 'bot');

            } catch (error) {
                hideTyping();
                addMsg('Maaf, sistem AI kami sedang mengalami gangguan koneksi. Silakan hubungi kami langsung via WhatsApp.', 'bot');
                console.error('Error Webhook:', error);
            }
        });
    </script>
