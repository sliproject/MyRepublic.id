    <style>
        /* ============================================================
           KHUSUS CUSTOM CSS LIVE CHAT (BAGIAN YANG DIPERBAIKI)
           ============================================================ */
        
        /* Container utama pesan chat, wajib menggunakan flex-col */
        #chat-messages {
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 16px;
            overflow-y: auto;
            background-color: #f8f9fa;
        }

        /* Wrapper baris untuk memisahkan posisi kanan dan kiri */
        .msg-row {
            display: flex;
            width: 100%;
        }
        /* Kalau USER: otomatis nempel ke kanan */
        .msg-row.user {
            justify-content: flex-end;
        }
        /* Kalau BOT: otomatis nempel ke kiri */
        .msg-row.bot {
            justify-content: flex-start;
        }

        /* Style dasar bubble chat */
        .chat-bubble {
            max-width: 80%;
            padding: 10px 16px;
            font-size: 14px;
            line-height: 1.5;
            word-wrap: break-word;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        /* BUBBLE USER: Warna Biru, Teks Putih, Sudut Kanan Bawah Lancip */
        .msg-row.user .chat-bubble {
            background-color: #2563eb;
            color: #ffffff;
            border-radius: 16px 16px 4px 16px;
        }

        /* BUBBLE BOT: Warna Abu-abu Terang, Teks Gelap, Sudut Kiri Bawah Lancip */
        .msg-row.bot .chat-bubble {
            background-color: #e9ecef;
            color: #212529;
            border-radius: 16px 16px 16px 4px;
        }

        /* Animasi Indikator Mengetik (Typing Indicator) Bot */
        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 12px 16px;
            background-color: #e9ecef;
            border-radius: 16px 16px 16px 4px;
            align-self: flex-start;
            width: fit-content;
        }
        .typing-indicator span {
            width: 6px;
            height: 6px;
            background-color: #6c757d;
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }
        .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
        
        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1.0); }
        }
    </style>
