                    <div class="faq-q">Apakah ada biaya instalasi? <span class="faq-arrow">+</span></div>
                    <div class="faq-a"><p>Tidak ada! Instalasi MyRepublic sepenuhnya gratis tanpa biaya tersembunyi.</p></div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-q">Berapa lama proses pemasangan? <span class="faq-arrow">+</span></div>
                    <div class="faq-a"><p>Proses instalasi biasanya memakan waktu 3–7 hari kerja setelah pendaftaran disetujui, tergantung ketersediaan teknisi di area Anda.</p></div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-q">Apakah ada kontrak minimal berlangganan? <span class="faq-arrow">+</span></div>
                    <div class="faq-a"><p>Paket bulanan tidak terikat kontrak panjang. Untuk Advance Payment (AP), masa berlangganan sesuai paket yang dipilih dengan keuntungan hemat lebih banyak.</p></div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-q">Apa itu paket Advance Payment 9+3 dan 12+6? <span class="faq-arrow">+</span></div>
                    <div class="faq-a"><p>AP 9+3: bayar 9 bulan di muka, gratis 3 bulan (total 12 bulan). AP 12+6: bayar 12 bulan di muka, gratis 6 bulan (total 18 bulan). Harga per bulan lebih hemat dibanding paket bulanan biasa.</p></div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-q">Apakah tersedia untuk area saya? <span class="faq-arrow">+</span></div>
                    <div class="faq-a"><p>Hubungi kami via WhatsApp atau klik tombol Daftar Sekarang untuk cek ketersediaan jaringan di alamat Anda.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-band">
        <div class="container">
            <div class="cta-box reveal">
                <h2>Siap Berlangganan?</h2>
                <p>Gratis instalasi. Internet cepat tanpa batas. Daftar sekarang dan nikmati koneksi terbaik.</p>
                <div class="cta-actions">
                    <a href="https://wa.me/6285167313400" class="btn-primary">💬 Daftar via WhatsApp</a>
                    <a href="#harga" class="btn-ghost">📦 Lihat Paket Lagi</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer>
        <div class="container">
            <div class="footer-logo">My<span>Republic</span></div>
            <p>© 2025 MyRepublic Indonesia · Internet Fiber Optic Terbaik · member of Sinarmas</p>
        </div>
    </footer>

    <!-- ── CHAT BUTTONS ── -->
    <div class="chat-buttons">
        <button class="chat-btn chat-btn-paket" id="btn-paket">
            <span class="chat-dot"></span> 🎧 Tanya Paket
        </button>
        <button class="chat-btn chat-btn-komplain" id="btn-komplain">
            📢 Komplain
        </button>
    </div>

    <!-- CHAT PAKET -->
    <div class="chat-window" id="win-paket">
        <div class="chat-header paket-header">
            <div class="chat-agent">
                <div class="agent-avatar">🤖</div>
                <div>
                    <div class="agent-name">AI Paket MyRepublic</div>
                    <div class="agent-status"><span class="status-online"></span> Online sekarang</div>
                </div>
            </div>
            <button class="close-chat" data-target="win-paket">×</button>
        </div>
        <div class="chat-body" id="msg-paket"></div>
        <div class="chat-footer">
            <input type="text" id="input-paket" class="chat-input" placeholder="Tanya soal paket internet..." autocomplete="off" />
            <button class="chat-send" id="send-paket">➤</button>
        </div>
    </div>

    <!-- CHAT KOMPLAIN -->
    <div class="chat-window" id="win-komplain">
        <div class="chat-header komplain-header">
            <div class="chat-agent">
                <div class="agent-avatar">📋</div>
                <div>
                    <div class="agent-name">AI Komplain MyRepublic</div>
                    <div class="agent-status"><span class="status-online"></span> Siap membantu</div>
                </div>
            </div>
            <button class="close-chat" data-target="win-komplain">×</button>
        </div>
        <div class="chat-body" id="msg-komplain"></div>
        <div class="chat-footer">
            <input type="text" id="input-komplain" class="chat-input" placeholder="Ceritakan masalah Anda..." autocomplete="off" />
            <button class="chat-send dark" id="send-komplain">➤</button>
        </div>
    </div>

    <script is:inline>
        // ── FAQ ACCORDION ──
        document.querySelectorAll('.faq-q').forEach(q => {
            q.addEventListener('click', () => {
                const item = q.parentElement;
                const isOpen = item.classList.contains('open');
                document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
                if (!isOpen) item.classList.add('open');
            });
        });

        // ── SCROLL REVEAL ──
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((e, i) => {
                if (e.isIntersecting) {
                    setTimeout(() => e.target.classList.add('visible'), i * 70);
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.08 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // ── PRICING TABS ──
        function switchTab(id, btn) {
            document.querySelectorAll('.pricing-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.ptab').forEach(b => b.classList.remove('active'));
            document.getElementById('panel-' + id).classList.add('active');
            btn.classList.add('active');
        }
        function switchSub(tabId, subId, btn) {
            const panel = document.getElementById('panel-' + tabId);
            panel.querySelectorAll('.subpanel').forEach(p => p.classList.remove('active'));
            panel.querySelectorAll('.psubtab').forEach(b => b.classList.remove('active'));
            document.getElementById(tabId + '-' + subId).classList.add('active');
            btn.classList.add('active');
        }

        // ── CHAT ENGINE ──
        // === EDIT WEBHOOK DI SINI ===
        const WEBHOOK_PAKET    = 'https://n8n.aleshatour.my.id/webhook/salesmyrep';
        const WEBHOOK_KOMPLAIN = 'https://n8n.aleshatour.my.id/webhook/komplain'; // <-- isi URL webhook komplain
        // ============================

        const sessionPaket    = 'paket_'    + Math.random().toString(36).substring(7);
        const sessionKomplain = 'komplain_' + Math.random().toString(36).substring(7);
        const historyKomplain = [];

        // Close buttons
        document.querySelectorAll('.close-chat').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById(btn.dataset.target).classList.remove('show');
            });
        });
        // Toggle (tutup yang lain)
        document.getElementById('btn-paket').addEventListener('click', () => {
            document.getElementById('win-komplain').classList.remove('show');
            document.getElementById('win-paket').classList.toggle('show');
        });
        document.getElementById('btn-komplain').addEventListener('click', () => {
            document.getElementById('win-paket').classList.remove('show');
            document.getElementById('win-komplain').classList.toggle('show');
        });

        // Helpers
        function addMsg(id, text, type) {
            const box = document.getElementById(id);
            const d = document.createElement('div');
            d.className = 'msg ' + type;
            d.textContent = text;
            box.appendChild(d);
            box.scrollTop = box.scrollHeight;
        }
        function showTyping(id, tid) {
            const box = document.getElementById(id);
            const t = document.createElement('div');
            t.className = 'typing'; t.id = tid;
            t.innerHTML = '<span></span><span></span><span></span>';
            box.appendChild(t); box.scrollTop = box.scrollHeight;
        }
        function hideTyping(tid) { const t = document.getElementById(tid); if (t) t.remove(); }
        async function postWebhook(url, payload) {
            const r = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
            return await r.json();
        }

        // Greetings
        window.addEventListener('load', () => {
            setTimeout(() => addMsg('msg-paket',
                'Halo! Tanya apa saja soal paket internet MyRepublic — harga, kecepatan, cara berlangganan, atau promo 😊', 'bot'), 400);
            setTimeout(() => addMsg('msg-komplain',
                'Halo! Saya asisten keluhan MyRepublic 🙏 Ceritakan masalah Anda — saya akan bantu selesaikan langsung di sini.', 'bot'), 400);
        });

        // Chat Paket
        document.getElementById('send-paket').addEventListener('click', sendPaket);
        document.getElementById('input-paket').addEventListener('keydown', e => { if (e.key === 'Enter') sendPaket(); });
        async function sendPaket() {
            const inp = document.getElementById('input-paket');
            const txt = inp.value.trim(); if (!txt) return;
            addMsg('msg-paket', txt, 'user'); inp.value = '';
            showTyping('msg-paket', 'tp-paket');
            try {
                const d = await postWebhook(WEBHOOK_PAKET, { type:'tanya_paket', message:txt, chatId:sessionPaket });
                hideTyping('tp-paket');
                addMsg('msg-paket', d.reply || d.output || d.message || 'Tim kami akan segera membalas!', 'bot');
            } catch { hideTyping('tp-paket'); addMsg('msg-paket', 'Maaf, koneksi bermasalah. Silakan coba kembali.', 'bot'); }
        }

        // Chat Komplain
        document.getElementById('send-komplain').addEventListener('click', sendKomplain);
        document.getElementById('input-komplain').addEventListener('keydown', e => { if (e.key === 'Enter') sendKomplain(); });
        async function sendKomplain() {
            const inp = document.getElementById('input-komplain');
            const txt = inp.value.trim(); if (!txt) return;
            addMsg('msg-komplain', txt, 'user');
            historyKomplain.push({ role:'user', content:txt });
            inp.value = '';
            showTyping('msg-komplain', 'tp-komplain');
            try {
                const d = await postWebhook(WEBHOOK_KOMPLAIN, {
                    type:'komplain', message:txt, chatId:sessionKomplain, history:historyKomplain, fcr_context:true
                });
                hideTyping('tp-komplain');
                const reply = d.reply || d.output || d.message || 'Pesan Anda sudah kami terima. Mohon tunggu sebentar.';
                addMsg('msg-komplain', reply, 'bot');
                historyKomplain.push({ role:'assistant', content:reply });
            } catch { hideTyping('tp-komplain'); addMsg('msg-komplain', 'Maaf, koneksi bermasalah. Silakan coba kembali.', 'bot'); }
        }
    </script>

    <!-- FAQ styles (inline untuk simplicity) -->
    <style>
        .faq-item { background:var(--navy); border:1px solid var(--border-soft); border-radius:12px; overflow:hidden; }
        .faq-q { padding:18px 22px; font-size:15px; font-weight:600; color:#fff; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:14px; user-select:none; }
        .faq-q:hover { color:var(--accent2); }
        .faq-arrow { font-size:18px; color:var(--accent); transition:transform .3s; flex-shrink:0; }
        .faq-item.open .faq-arrow { transform:rotate(45deg); }
        .faq-a { max-height:0; overflow:hidden; transition:max-height .35s ease; }
        .faq-item.open .faq-a { max-height:200px; }
        .faq-a p { padding:0 22px 18px; font-size:14px; color:var(--text-muted); line-height:1.8; }
    </style>
</body>
</html>
